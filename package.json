{
  "name": "open-backend-cloud",
  "version": "0.0.0",
  "private": true,
  "description": "FOSS Supabase Cloud-like control plane built around Supabase OSS.",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "biome:check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run check:base && bun run control-api:check",
    "docs:check": "bun scripts/check-doc-links.ts",
    "foundation:check": "bun scripts/check-foundation.ts",
    "hooks:install": "lefthook install",
    "supabase:init": "bunx supabase init",
    "supabase:start": "bunx supabase start",
    "supabase:stop": "bunx supabase stop",
    "supabase:stop:clean": "bunx supabase stop --no-backup",
    "supabase:status": "bunx supabase status",
    "supabase:status:env": "bunx supabase status -o env",
    "supabase:reset": "bunx supabase db reset",
    "supabase:lint": "bunx supabase db lint --local --level warning",
    "supabase:test": "bunx supabase test db --local",
    "supabase:diff": "bunx supabase db diff --local",
    "supabase:migration:new": "bunx supabase migration new",
    "supabase:types": "mkdir -p packages/database/src/generated && bunx supabase gen types typescript --local > packages/database/src/generated/supabase.ts",
    "dev:runtime": "bun run supabase:start && bun run supabase:status",
    "verify:runtime": "bun run supabase:status && bun run supabase:test && bun run supabase:types",
    "control-plane:check": "bun scripts/check-control-plane-schema.ts",
    "control-api:dev": "cd services/control-api && bun run dev",
    "control-api:start": "cd services/control-api && bun run start",
    "control-api:check": "cd services/control-api && bun run check",
    "control-api:test": "cd services/control-api && bun test",
    "check:base": "bun run typecheck && bun run biome:check && bun run docs:check && bun run foundation:check && bun run control-plane:check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.0.0",
    "@types/node": "^22.0.0",
    "lefthook": "^1.0.0",
    "supabase": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "type": "module"
}
