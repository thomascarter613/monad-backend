# Open Backend Cloud local development example.
# Copy to .env.local for local-only values. Do not commit real secrets.

NODE_ENV=development
OBC_ENVIRONMENT=local
OBC_LOG_LEVEL=debug

# Supabase local defaults are emitted by `bun run supabase:status:env` after startup.
# These placeholders are intentionally non-secret examples.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key-from-supabase-status
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Future control-plane database URL. WP-0002 does not create the control-plane schema yet.
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
