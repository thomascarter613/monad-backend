{
  "name": "@monad-backend/control-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "bun test && bun run typecheck",
    "db:check": "bun src/scripts/check-database.ts",
    "auth:hash": "bun src/scripts/hash-api-key.ts"
  },
  "dependencies": {
    "@monad-backend/config": "workspace:*",
    "elysia": "latest",
    "@monad-backend/database": "workspace:*",
    "@monad-backend/auth": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
